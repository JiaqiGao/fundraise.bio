// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?   @db.VarChar(150)
  email         String?   @unique @db.VarChar(150)
  emailVerified DateTime?
  image         String?
  username      String?   @unique @db.VarChar(150)
  accounts      Account[]
  sessions      Session[]
  profileCharities ProfileCharity[]
}

model VerificationToken {
  identifier String   @db.VarChar(150)
  token      String   @unique @db.VarChar(150)
  expires    DateTime

  @@unique([identifier, token])
}

model Charity {
  id                  String           @id @default(cuid())
  name                String           @db.VarChar(150)
  description         String
  giveWellRating      String?
  charityWatchRating  String?
  donationUrl         String
  profileCharities    ProfileCharity[]
}

model ProfileCharity {
  id          String           @id @default(cuid())
  userId      String
  charityId   String
  viewCount   Int              @default(0)
  clickCount  Int              @default(0)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  charity     Charity          @relation(fields: [charityId], references: [id], onDelete: Cascade)
  donations   DonationReport[]

  @@unique([userId, charityId])
}

model DonationReport {
  id               String         @id @default(cuid())
  profileCharityId String
  amount           Float
  donorName        String?        @db.VarChar(150)
  createdAt        DateTime       @default(now())
  profileCharity   ProfileCharity @relation(fields: [profileCharityId], references: [id], onDelete: Cascade)
}
